generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==========================================
// Core tables (genuine persistent state)
// ==========================================

// User model for authentication
model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  role      String    @default("user")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  projects  Project[]

  @@map("users")
}

// Project model for multi-project support
model Project {
  id          String   @id @default(cuid())
  name        String
  path        String
  description String?
  isActive    Boolean  @default(false)
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  pages         Page[]
  implementHistory ImplementHistory[]

  @@unique([userId, path])
  @@index([userId, isActive])
  @@map("projects")
}

// Implementation history for tracking changes and enabling undo
model ImplementHistory {
  id            String   @id @default(cuid())
  pageId        String
  projectId     String?
  promptContent String   // The prompt that was implemented
  scope         String   @default("single") // "single", "partial", "multi"
  filesChanged  String   // JSON array of { filePath, backupPath, action }
  status        String   @default("applied") // "applied", "reverted"
  createdAt     DateTime @default(now())

  project       Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId, status])
  @@map("implement_history")
}

// ==========================================
// Cache tables (disposable, rebuilt from filesystem)
// ==========================================

// File category classification
enum FileCategory {
  FRONTEND
  BACKEND
  DATABASE
}

// Enum for prompt types
enum PromptType {
  NLP        // User-friendly, natural language prompts
  DEVELOPER  // Technical, concise developer prompts
}

// FileIndex / Page cache — lightweight file metadata + mtime for dirty checking
model Page {
  id            String       @id @default(cuid())
  filePath      String
  componentName String
  totalLines    Int
  purpose       String
  category      FileCategory @default(BACKEND)
  promptFilePath String?     // Relative path to the source .txt file
  rawContent    String?      // Full original text content (cache)
  contentHash   String?      // SHA-256 hash of prompt file for dirty checking
  fileMtime     DateTime?    // Last modified time of prompt file on disk
  projectId     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  project       Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sections      Section[]

  @@unique([projectId, filePath])
  @@index([projectId])
  @@map("pages")
}

// Section cache — parsed sections within a prompt file
model Section {
  id        String   @id @default(cuid())
  pageId    String
  name      String
  startLine Int
  endLine   Int
  purpose   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  page    Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  prompts Prompt[]

  @@index([pageId])
  @@map("sections")
}

// Prompt cache — individual prompt templates per section
model Prompt {
  id           String     @id @default(cuid())
  sectionId    String
  template     String
  example      String?
  description  String?
  lineNumber   Int        @default(0)
  promptType   PromptType @default(NLP)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
  @@map("prompts")
}
